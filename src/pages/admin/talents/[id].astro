---
import Layout from '../../../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Edit Talent - Admin">
  <div id="auth-check" class="hidden">
    <div class="min-h-screen bg-gray-100">
      <nav class="bg-white shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center">
              <a href="/admin" class="text-xl font-bold">← Back to Dashboard</a>
            </div>
            <div class="flex items-center">
              <button
                id="logout-btn"
                class="ml-4 px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900"
              >
                Logout
              </button>
            </div>
          </div>
        </div>
      </nav>

      <main class="max-w-4xl mx-auto py-6 sm:px-6 lg:px-8">
        <div class="px-4 py-6 sm:px-0">
          <h2 class="text-2xl font-semibold text-gray-900 mb-6">Edit Talent</h2>

          <div id="loading" class="text-center py-12">
            <p class="text-gray-500">Loading talent...</p>
          </div>

          <form id="talent-form" class="hidden space-y-6 bg-white shadow px-4 py-5 sm:rounded-lg sm:p-6">
            <input type="hidden" id="talent-id" name="talentId" />

            <div class="grid grid-cols-1 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700">Name *</label>
                <input
                  type="text"
                  name="name"
                  id="name"
                  required
                  class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                />
              </div>

              <div>
                <label for="specialty" class="block text-sm font-medium text-gray-700">Specialty *</label>
                <input
                  type="text"
                  name="specialty"
                  id="specialty"
                  required
                  class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                />
              </div>

              <div>
                <label for="description" class="block text-sm font-medium text-gray-700">Description *</label>
                <textarea
                  name="description"
                  id="description"
                  rows="4"
                  required
                  class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                ></textarea>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Current Main Image</label>
                <div id="current-image" class="mb-2"></div>
                <label for="image" class="block text-sm font-medium text-gray-700">Upload New Main Image</label>
                <input
                  type="file"
                  name="image"
                  id="image"
                  accept="image/*"
                  class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Current Gallery Images</label>
                <div id="current-gallery" class="flex flex-wrap gap-2 mb-2"></div>
                <label for="gallery" class="block text-sm font-medium text-gray-700">Upload New Gallery Images</label>
                <input
                  type="file"
                  name="gallery"
                  id="gallery"
                  accept="image/*"
                  multiple
                  class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Current PDF</label>
                <div id="current-pdf" class="mb-2"></div>
                <label for="pdf" class="block text-sm font-medium text-gray-700">Upload New Sedcard PDF</label>
                <input
                  type="file"
                  name="pdf"
                  id="pdf"
                  accept="application/pdf"
                  class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100"
                />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="location" class="block text-sm font-medium text-gray-700">Location</label>
                  <input
                    type="text"
                    name="location"
                    id="location"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>

                <div>
                  <label for="city" class="block text-sm font-medium text-gray-700">City</label>
                  <input
                    type="text"
                    name="city"
                    id="city"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="age" class="block text-sm font-medium text-gray-700">Age</label>
                  <input
                    type="text"
                    name="age"
                    id="age"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>

                <div>
                  <label for="birth" class="block text-sm font-medium text-gray-700">Birth Date</label>
                  <input
                    type="text"
                    name="birth"
                    id="birth"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>
              </div>

              <div class="grid grid-cols-3 gap-4">
                <div>
                  <label for="height" class="block text-sm font-medium text-gray-700">Height</label>
                  <input
                    type="text"
                    name="height"
                    id="height"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>

                <div>
                  <label for="eyeColor" class="block text-sm font-medium text-gray-700">Eye Color</label>
                  <input
                    type="text"
                    name="eyeColor"
                    id="eyeColor"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>

                <div>
                  <label for="hairColor" class="block text-sm font-medium text-gray-700">Hair Color</label>
                  <input
                    type="text"
                    name="hairColor"
                    id="hairColor"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>
              </div>

              <div class="grid grid-cols-3 gap-4">
                <div>
                  <label for="shoeSize" class="block text-sm font-medium text-gray-700">Shoe Size</label>
                  <input
                    type="text"
                    name="shoeSize"
                    id="shoeSize"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>

                <div>
                  <label for="dressSize" class="block text-sm font-medium text-gray-700">Dress Size</label>
                  <input
                    type="text"
                    name="dressSize"
                    id="dressSize"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  />
                </div>

                <div>
                  <label for="pronouns" class="block text-sm font-medium text-gray-700">Pronouns</label>
                  <input
                    type="text"
                    name="pronouns"
                    id="pronouns"
                    class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                    placeholder="e.g., he/him, she/her, they/them"
                  />
                </div>
              </div>

              <div>
                <label for="specialFeatures" class="block text-sm font-medium text-gray-700">Special Features</label>
                <input
                  type="text"
                  name="specialFeatures"
                  id="specialFeatures"
                  class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                  placeholder="Comma-separated"
                />
              </div>

              <div>
                <label for="portfolioUrl" class="block text-sm font-medium text-gray-700">Portfolio URL</label>
                <input
                  type="url"
                  name="portfolioUrl"
                  id="portfolioUrl"
                  class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"
                />
              </div>

              <div class="flex items-start">
                <div class="flex items-center h-5">
                  <input
                    id="enabled"
                    name="enabled"
                    type="checkbox"
                    class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded"
                  />
                </div>
                <div class="ml-3 text-sm">
                  <label for="enabled" class="font-medium text-gray-700">Enabled</label>
                  <p class="text-gray-500">Show this talent on the public website</p>
                </div>
              </div>
            </div>

            <div id="error-message" class="hidden text-red-600 text-sm"></div>
            <div id="progress-message" class="hidden text-indigo-600 text-sm"></div>

            <div class="flex justify-end space-x-3">
              <a
                href="/admin"
                class="inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
              >
                Cancel
              </a>
              <button
                type="submit"
                id="submit-btn"
                class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700"
              >
                Update Talent
              </button>
            </div>
          </form>
        </div>
      </main>
    </div>
  </div>

  <div id="loading-auth" class="min-h-screen flex items-center justify-center">
    <p class="text-gray-500">Checking authentication...</p>
  </div>
</Layout>

<script>
  import { getCurrentUser, logOut } from '../../../lib/auth';
  import { getTalentById, updateTalent, uploadTalentImage, uploadTalentPdf } from '../../../lib/admin-talents';

  let currentTalent: any = null;

  async function checkAuth() {
    const user = await getCurrentUser();

    if (!user) {
      window.location.href = '/admin/login';
      return;
    }

    document.getElementById('loading-auth')?.classList.add('hidden');
    document.getElementById('auth-check')?.classList.remove('hidden');

    await loadTalent();
  }

  async function loadTalent() {
    const urlParts = window.location.pathname.split('/');
    const talentId = urlParts[urlParts.length - 1];

    try {
      const talent = await getTalentById(talentId);

      if (!talent) {
        alert('Talent not found');
        window.location.href = '/admin';
        return;
      }

      currentTalent = talent;

      (document.getElementById('talent-id') as HTMLInputElement).value = talent.id;
      (document.getElementById('name') as HTMLInputElement).value = talent.name;
      (document.getElementById('specialty') as HTMLInputElement).value = talent.specialty;
      (document.getElementById('description') as HTMLTextAreaElement).value = talent.description;
      (document.getElementById('location') as HTMLInputElement).value = talent.location || '';
      (document.getElementById('city') as HTMLInputElement).value = talent.city || '';
      (document.getElementById('age') as HTMLInputElement).value = talent.age?.toString() || '';
      (document.getElementById('birth') as HTMLInputElement).value = talent.birth || '';
      (document.getElementById('height') as HTMLInputElement).value = talent.height || '';
      (document.getElementById('eyeColor') as HTMLInputElement).value = talent.eyeColor || '';
      (document.getElementById('hairColor') as HTMLInputElement).value = talent.hairColor || '';
      (document.getElementById('shoeSize') as HTMLInputElement).value = talent.shoeSize || '';
      (document.getElementById('dressSize') as HTMLInputElement).value = talent.dressSize || '';
      (document.getElementById('pronouns') as HTMLInputElement).value = talent.pronouns || '';
      (document.getElementById('portfolioUrl') as HTMLInputElement).value = talent.portfolioUrl || '';
      (document.getElementById('enabled') as HTMLInputElement).checked = talent.enabled !== false;

      // Load specialties into specialFeatures input
      if (talent.specialties && Array.isArray(talent.specialties)) {
        const validFeatures = talent.specialties.filter(f => f && typeof f === 'string');
        (document.getElementById('specialFeatures') as HTMLInputElement).value = validFeatures.join(', ');
      } else if (talent.specialFeatures && Array.isArray(talent.specialFeatures)) {
        // Fallback for old data
        const validFeatures = talent.specialFeatures.filter(f => f && typeof f === 'string');
        (document.getElementById('specialFeatures') as HTMLInputElement).value = validFeatures.join(', ');
      }

      // Display current main image
      const currentImageDiv = document.getElementById('current-image');
      if (talent.image && currentImageDiv) {
        currentImageDiv.innerHTML = `<img src="${talent.image}" alt="${talent.name}" class="h-32 w-32 object-cover rounded" />`;
      }

      // Display current gallery
      const currentGalleryDiv = document.getElementById('current-gallery');
      if (talent.imgs && talent.imgs.length > 0 && currentGalleryDiv) {
        currentGalleryDiv.innerHTML = talent.imgs
          .map((img: string) => `<img src="${img}" class="h-24 w-24 object-cover rounded" />`)
          .join('');
      }

      // Display current PDF
      const currentPdfDiv = document.getElementById('current-pdf');
      if (talent.pdfUrl && currentPdfDiv) {
        currentPdfDiv.innerHTML = `<a href="${talent.pdfUrl}" target="_blank" class="text-indigo-600 hover:text-indigo-900">View current PDF</a>`;
      }

      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('talent-form')?.classList.remove('hidden');
    } catch (error) {
      console.error('Error loading talent:', error);
      alert('Error loading talent');
      window.location.href = '/admin';
    }
  }

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    try {
      await logOut();
      window.location.href = '/admin/login';
    } catch (error) {
      console.error('Error logging out:', error);
    }
  });

  const form = document.getElementById('talent-form') as HTMLFormElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  const progressMessage = document.getElementById('progress-message') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    console.log('=== FORM SUBMIT STARTED ===');

    const formData = new FormData(form);
    const talentId = formData.get('talentId') as string;

    errorMessage.classList.add('hidden');
    progressMessage.classList.remove('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Updating...';

    try {
      progressMessage.textContent = 'Updating talent...';

      const updateData: any = {
        name: formData.get('name') as string,
        specialty: formData.get('specialty') as string,
        description: formData.get('description') as string,
        enabled: formData.get('enabled') === 'on',
      };
      console.log('Basic update data prepared:', updateData);

      // Only add optional fields if they have values
      const location = formData.get('location') as string;
      if (location) updateData.location = location;

      const city = formData.get('city') as string;
      if (city) updateData.city = city;

      const age = formData.get('age') as string;
      if (age) updateData.age = age;

      const birth = formData.get('birth') as string;
      if (birth) updateData.birth = birth;

      const height = formData.get('height') as string;
      if (height) updateData.height = height;

      const eyeColor = formData.get('eyeColor') as string;
      if (eyeColor) updateData.eyeColor = eyeColor;

      const hairColor = formData.get('hairColor') as string;
      if (hairColor) updateData.hairColor = hairColor;

      const shoeSize = formData.get('shoeSize') as string;
      if (shoeSize) updateData.shoeSize = shoeSize;

      const dressSize = formData.get('dressSize') as string;
      if (dressSize) updateData.dressSize = dressSize;

      const pronouns = formData.get('pronouns') as string;
      if (pronouns) updateData.pronouns = pronouns;

      const portfolioUrl = formData.get('portfolioUrl') as string;
      if (portfolioUrl) updateData.portfolioUrl = portfolioUrl;

      // Parse special features array - save to specialties field
      const specialFeaturesStr = formData.get('specialFeatures') as string;
      console.log('Special features string from form:', specialFeaturesStr);
      if (specialFeaturesStr && specialFeaturesStr.trim()) {
        updateData.specialties = specialFeaturesStr.split(',').map((s) => s.trim()).filter(Boolean);
        console.log('Parsed specialties array:', updateData.specialties);
      }

      // Upload new main image if provided
      const imageFile = (document.getElementById('image') as HTMLInputElement).files?.[0];
      if (imageFile) {
        progressMessage.textContent = 'Uploading new main image...';
        const imageUrl = await uploadTalentImage(imageFile, talentId, 'main');
        updateData.image = imageUrl;
      }

      // Upload new gallery images if provided
      const galleryFiles = (document.getElementById('gallery') as HTMLInputElement).files;
      if (galleryFiles && galleryFiles.length > 0) {
        progressMessage.textContent = 'Uploading new gallery images...';
        const newGalleryUrls: string[] = [];
        for (let i = 0; i < galleryFiles.length; i++) {
          const url = await uploadTalentImage(galleryFiles[i], talentId, 'gallery');
          newGalleryUrls.push(url);
        }
        // Append to existing gallery images
        updateData.imgs = [...(currentTalent.imgs || []), ...newGalleryUrls];
      }

      // Upload new PDF if provided
      const pdfFile = (document.getElementById('pdf') as HTMLInputElement).files?.[0];
      if (pdfFile) {
        progressMessage.textContent = 'Uploading new PDF...';
        const pdfUrl = await uploadTalentPdf(pdfFile, talentId);
        updateData.pdfUrl = pdfUrl;
      }

      console.log('Final updateData before calling updateTalent:', JSON.stringify(updateData, null, 2));
      await updateTalent(talentId, updateData);

      progressMessage.textContent = 'Success! Redirecting...';
      setTimeout(() => {
        window.location.href = '/admin';
      }, 1000);
    } catch (error: any) {
      console.error('Error updating talent:', error);
      errorMessage.textContent = error.message || 'Failed to update talent';
      errorMessage.classList.remove('hidden');
      progressMessage.classList.add('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Update Talent';
    }
  });

  checkAuth();
</script>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Dashboard - Unides">
  <div id="auth-check" class="hidden">
    <div class="min-h-screen bg-gray-100">
      <nav class="bg-white shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center">
              <h1 class="text-xl font-bold">Admin Dashboard</h1>
            </div>
            <div class="flex items-center">
              <button
                id="logout-btn"
                class="ml-4 px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900"
              >
                Logout
              </button>
            </div>
          </div>
        </div>
      </nav>

      <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <div class="px-4 py-6 sm:px-0">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-semibold text-gray-900">Talents</h2>
            <a
              href="/admin/talents/new"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700"
            >
              + Add New Talent
            </a>
          </div>

          <div id="loading" class="text-center py-12">
            <p class="text-gray-500">Loading talents...</p>
          </div>

          <div id="talents-list" class="hidden bg-white shadow overflow-hidden sm:rounded-md">
            <ul class="divide-y divide-gray-200"></ul>
          </div>

          <div id="empty-state" class="hidden text-center py-12">
            <p class="text-gray-500">No talents found. Create your first talent!</p>
          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="loading-auth" class="min-h-screen flex items-center justify-center">
    <p class="text-gray-500">Checking authentication...</p>
  </div>
</Layout>

<script>
  import { getCurrentUser } from '../../lib/auth';
  import { logOut } from '../../lib/auth';
  import { getTalents } from '../../lib/talents';
  import { deleteTalent } from '../../lib/admin-talents';

  async function checkAuth() {
    const user = await getCurrentUser();

    if (!user) {
      window.location.href = '/admin/login';
      return;
    }

    document.getElementById('loading-auth')?.classList.add('hidden');
    document.getElementById('auth-check')?.classList.remove('hidden');

    loadTalents();
  }

  async function loadTalents() {
    const loading = document.getElementById('loading');
    const talentsList = document.getElementById('talents-list');
    const emptyState = document.getElementById('empty-state');

    try {
      const talents = await getTalents();

      loading?.classList.add('hidden');

      if (talents.length === 0) {
        emptyState?.classList.remove('hidden');
        return;
      }

      const ul = talentsList?.querySelector('ul');
      if (!ul) return;

      ul.innerHTML = talents
        .map(
          (talent) => `
        <li>
          <div class="px-4 py-4 sm:px-6 hover:bg-gray-50">
            <div class="flex items-center justify-between">
              <div class="flex items-center min-w-0 flex-1">
                ${
                  talent.image
                    ? `<img src="${talent.image}" alt="${talent.name}" class="h-12 w-12 rounded-full object-cover mr-4" />`
                    : '<div class="h-12 w-12 rounded-full bg-gray-200 mr-4"></div>'
                }
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium text-indigo-600 truncate">
                    ${talent.name}
                  </p>
                  <p class="text-sm text-gray-500">
                    ${talent.specialty || 'No specialty'}
                  </p>
                  <p class="text-xs text-gray-400">
                    ${talent.enabled !== false ? 'Enabled' : 'Disabled'}
                  </p>
                </div>
              </div>
              <div class="flex space-x-2">
                <a
                  href="/admin/talents/${talent.id}"
                  class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                >
                  Edit
                </a>
                <button
                  data-talent-id="${talent.id}"
                  data-talent-name="${talent.name}"
                  class="delete-btn inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-red-600 hover:bg-red-700"
                >
                  Delete
                </button>
              </div>
            </div>
          </div>
        </li>
      `
        )
        .join('');

      talentsList?.classList.remove('hidden');

      // Add delete handlers
      document.querySelectorAll('.delete-btn').forEach((btn) => {
        btn.addEventListener('click', handleDelete);
      });
    } catch (error) {
      console.error('Error loading talents:', error);
      loading!.textContent = 'Error loading talents. Please try again.';
    }
  }

  async function handleDelete(e: Event) {
    const btn = e.target as HTMLButtonElement;
    const talentId = btn.dataset.talentId;
    const talentName = btn.dataset.talentName;

    if (!talentId) return;

    if (!confirm(`Are you sure you want to delete ${talentName}? This action cannot be undone.`)) {
      return;
    }

    try {
      await deleteTalent(talentId);
      window.location.reload();
    } catch (error) {
      console.error('Error deleting talent:', error);
      alert('Failed to delete talent. Please try again.');
    }
  }

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    try {
      await logOut();
      window.location.href = '/admin/login';
    } catch (error) {
      console.error('Error logging out:', error);
    }
  });

  checkAuth();
</script>
</Layout>

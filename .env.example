# Firebase Configuration (Public - accessible in browser)
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id

# S3 Configuration (Server-side only - NEVER exposed to browser)
# IMPORTANT: Do NOT use AWS_ prefix on AWS Amplify (reserved by AWS)
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_REGION=eu-central-1
S3_BUCKET=your-bucket-name
S3_FOLDER_PREFIX=talents/
